# Supabase client-side/read keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key for inserts/uploads/admin API routes. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used by /api/storage/upload
SUPABASE_STORAGE_BUCKET=archive-assets

# Simple write lock for /admin and write API routes. Set this in Vercel too.
ADMIN_WRITE_KEY=change-this-long-random-string

# Optional: public site URL used by RSS.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: used by revalidation route if you add webhook-driven revalidation later.
REVALIDATE_SECRET=change-this-too
